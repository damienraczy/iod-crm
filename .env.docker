# Docker development environment variables
# Copy to .env.docker.local and customize if needed

# Django
SECRET_KEY=django-insecure-docker-dev-key-change-in-production
DEBUG=True
ENV_TYPE=dev
ALLOWED_HOSTS=localhost,127.0.0.1,backend
DOMAIN_NAME=http://localhost:8000
SWAGGER_ROOT_URL=http://localhost:8000

# Database (must match docker-compose db service)
DBNAME=crm_db
DBUSER=crm_user
DBPASSWORD=crm_password
DBHOST=db
DBPORT=5432

# Postgres superuser (used by db service to create the database)
POSTGRES_DB=crm_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email (SMTP configuration for A2 Hosting)
EMAIL_BACKEND="django.core.mail.backends.smtp.EmailBackend"
EMAIL_HOST="train.iod.nc"
EMAIL_PORT="587"
EMAIL_USE_TLS="True"
EMAIL_HOST_USER="ext1@train.iod.nc"
EMAIL_HOST_PASSWORD="iodxt6871"
DEFAULT_FROM_EMAIL="ext1@train.iod.nc"
ADMIN_EMAIL="ext1@train.iod.nc"
ADMIN_PASSWORD=admin

# CORS
CORS_ALLOW_ALL=True

# Google OAuth (leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Frontend (Use internal docker service name for server-side requests)
PUBLIC_DJANGO_API_URL=http://backend:8000

OLLAMA_CLOUD_URL=https://ollama.com/api/generate
OLLAMA_API_KEY=59c3dfa10e67449ea0a677519ab190e3.Xl2MG5b1AjVfRhxPcigBgud7
